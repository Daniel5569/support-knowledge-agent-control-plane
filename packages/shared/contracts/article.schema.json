{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/article.schema.json",
  "title": "KnowledgeArticle",
  "type": "object",
  "required": ["id", "title", "productArea", "body", "sourceUrl", "owner", "lastReviewedAt", "freshnessStatus", "version"],
  "properties": {
    "id": { "type": "string", "pattern": "^KB-[0-9]+$" },
    "title": { "type": "string", "minLength": 1 },
    "productArea": { "type": "string", "minLength": 1 },
    "body": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "lastReviewedAt": { "type": "string", "format": "date" },
    "freshnessStatus": { "type": "string", "enum": ["fresh", "review_due", "stale"] },
    "version": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
