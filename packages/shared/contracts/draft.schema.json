{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/draft.schema.json",
  "title": "AgentDraft",
  "type": "object",
  "required": ["id", "ticketId", "responseText", "citations", "confidence", "missingInfo", "proposedAction", "riskFlags"],
  "properties": {
    "id": { "type": "string", "pattern": "^DRF-[0-9]+$" },
    "ticketId": { "type": "string", "pattern": "^TCK-[0-9]+$" },
    "responseText": { "type": "string", "minLength": 1 },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["articleId", "title", "sourceUrl"],
        "properties": {
          "articleId": { "type": "string" },
          "title": { "type": "string" },
          "sourceUrl": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "missingInfo": { "type": "array", "items": { "type": "string" } },
    "proposedAction": { "type": "string", "enum": ["auto_reply", "request_clarification", "escalate", "kb_review"] },
    "riskFlags": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
